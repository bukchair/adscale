# ─────────────────────────────────────────────
# AdScale AI — Environment Variables
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# WooCommerce
WOOCOMMERCE_URL=https://your-store.com

# Google OAuth2 (shared by Google Ads + Merchant Center)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# Google Ads
GOOGLE_ADS_CUSTOMER_ID=         # e.g. 1234567890 (without dashes)
GOOGLE_ADS_DEVELOPER_TOKEN=

# Google Merchant Center
GMC_MERCHANT_ID=                 # Numeric merchant ID from Merchant Center

# Google Analytics 4 (Service Account)
GA4_CLIENT_EMAIL=                # service-account@project.iam.gserviceaccount.com
GA4_PRIVATE_KEY=                 # -----BEGIN RSA PRIVATE KEY----- (paste with \n)
GA4_PROPERTY_ID=                 # e.g. 123456789

# Google Search Console
GSC_SITE_URL=                    # e.g. https://your-store.com

# Meta (Facebook/Instagram)
META_ACCESS_TOKEN=               # System User token (never expires)
META_AD_ACCOUNT_ID=              # e.g. 123456789 (without act_ prefix)
META_PIXEL_ID=                   # Pixel ID for website audiences

# TikTok Ads
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=
