// AdScale — Production Prisma Schema
// PostgreSQL + Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// IDENTITY & TENANCY
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  role         UserRole @default(MEMBER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships   OrgMember[]
  auditLogs     AuditLog[]
  approvals     ApprovalRequest[] @relation("ApprovedBy")
  createdByLogs AuditLog[]        @relation("CreatedByUser")

  @@index([email])
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      OrgPlan  @default(FREE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members         OrgMember[]
  adAccounts      AdAccount[]
  storeIntegrations StoreIntegration[]
  featureFlags    FeatureFlag[]
  settings        Setting[]
  alerts          Alert[]
  syncJobs        SyncJob[]

  @@index([slug])
}

model OrgMember {
  id     String   @id @default(cuid())
  role   OrgRole  @default(VIEWER)
  joinedAt DateTime @default(now())

  userId String
  orgId  String
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@index([orgId])
}

// ─────────────────────────────────────────────────────────────────────────────
// AD PLATFORM INTEGRATIONS
// ─────────────────────────────────────────────────────────────────────────────

model AdAccount {
  id           String    @id @default(cuid())
  platform     Platform
  externalId   String    // platform's account ID
  name         String
  currency     String    @default("ILS")
  timezone     String    @default("Asia/Jerusalem")
  accessToken  String?   // encrypted
  refreshToken String?   // encrypted
  tokenExpiry  DateTime?
  isActive     Boolean   @default(true)
  lastSyncAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  campaigns   Campaign[]
  syncJobs    SyncJob[]
  dailyMetrics DailyMetric[]

  @@unique([orgId, platform, externalId])
  @@index([orgId, platform])
}

model StoreIntegration {
  id           String        @id @default(cuid())
  platform     StorePlatform
  storeUrl     String
  apiKey       String?       // encrypted
  apiSecret    String?       // encrypted
  accessToken  String?       // encrypted
  isActive     Boolean       @default(true)
  lastSyncAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  products  Product[]
  orders    Order[]
  syncJobs  SyncJob[]

  @@unique([orgId, platform, storeUrl])
  @@index([orgId])
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMPAIGN HIERARCHY
// ─────────────────────────────────────────────────────────────────────────────

model Campaign {
  id           String         @id @default(cuid())
  externalId   String
  name         String
  status       CampaignStatus @default(ACTIVE)
  type         CampaignType   @default(SEARCH)
  budgetAmount Decimal        @db.Decimal(12, 2)
  budgetType   BudgetType     @default(DAILY)
  bidStrategy  String?
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  adAccountId String
  adAccount   AdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)

  adGroups     AdGroup[]
  dailyMetrics DailyMetric[]
  hourlyMetrics HourlyMetric[]
  searchTerms  SearchTerm[]
  recommendations AiRecommendation[]
  optimizationActions OptimizationAction[]

  @@unique([adAccountId, externalId])
  @@index([adAccountId, status])
}

model AdGroup {
  id         String        @id @default(cuid())
  externalId String
  name       String
  status     CampaignStatus @default(ACTIVE)
  bidAmount  Decimal?      @db.Decimal(12, 2)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  ads      Ad[]
  keywords Keyword[]

  @@unique([campaignId, externalId])
  @@index([campaignId])
}

model Ad {
  id              String     @id @default(cuid())
  externalId      String
  type            AdType     @default(RSA)
  status          CampaignStatus @default(ACTIVE)
  headlines       String[]
  descriptions    String[]
  finalUrl        String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  adGroupId String
  adGroup   AdGroup @relation(fields: [adGroupId], references: [id], onDelete: Cascade)

  creativeVariants CreativeVariant[]

  @@unique([adGroupId, externalId])
}

model Keyword {
  id         String         @id @default(cuid())
  externalId String?
  text       String
  matchType  MatchType      @default(BROAD)
  status     CampaignStatus @default(ACTIVE)
  bidAmount  Decimal?       @db.Decimal(12, 2)
  qualityScore Int?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  adGroupId String
  adGroup   AdGroup @relation(fields: [adGroupId], references: [id], onDelete: Cascade)

  @@index([adGroupId])
  @@index([text])
}

// ─────────────────────────────────────────────────────────────────────────────
// SEARCH TERMS
// ─────────────────────────────────────────────────────────────────────────────

model SearchTerm {
  id             String      @id @default(cuid())
  query          String
  intent         SearchIntent @default(UNKNOWN)
  intentScore    Float?       // 0-1 confidence
  intentReason   String?
  queryScore     Int?         // 0-100
  riskLevel      RiskLevel?
  impressions    Int          @default(0)
  clicks         Int          @default(0)
  cost           Decimal      @db.Decimal(12, 2) @default(0)
  conversions    Float        @default(0)
  conversionValue Decimal     @db.Decimal(12, 2) @default(0)
  ctr            Float?
  cpc            Decimal?     @db.Decimal(12, 2)
  cpa            Decimal?     @db.Decimal(12, 2)
  roas           Float?
  dateFrom       DateTime
  dateTo         DateTime
  classifiedAt   DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  negKwSuggestions NegativeKeywordSuggestion[]

  @@index([campaignId, dateFrom])
  @@index([query])
  @@index([intent])
  @@index([queryScore])
}

// ─────────────────────────────────────────────────────────────────────────────
// PRODUCTS & ORDERS
// ─────────────────────────────────────────────────────────────────────────────

model Product {
  id              String   @id @default(cuid())
  externalId      String
  sku             String?
  name            String
  description     String?
  price           Decimal  @db.Decimal(12, 2)
  salePrice       Decimal? @db.Decimal(12, 2)
  cost            Decimal? @db.Decimal(12, 2)  // COGS
  shippingCost    Decimal? @db.Decimal(12, 2)
  category        String?
  tags            String[]
  imageUrl        String?
  isActive        Boolean  @default(true)
  stock           Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  storeId String
  store   StoreIntegration @relation(fields: [storeId], references: [id], onDelete: Cascade)

  costs      ProductCost[]
  orderItems OrderItem[]

  @@unique([storeId, externalId])
  @@index([storeId])
  @@index([sku])
}

model ProductCost {
  id           String   @id @default(cuid())
  cogs         Decimal  @db.Decimal(12, 2)
  shipping     Decimal  @db.Decimal(12, 2) @default(0)
  fees         Decimal  @db.Decimal(12, 2) @default(0)  // platform fees
  effectiveFrom DateTime
  effectiveTo  DateTime?
  createdAt    DateTime @default(now())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, effectiveFrom])
}

model Order {
  id          String      @id @default(cuid())
  externalId  String
  status      OrderStatus @default(PROCESSING)
  total       Decimal     @db.Decimal(12, 2)
  subtotal    Decimal     @db.Decimal(12, 2)
  shipping    Decimal     @db.Decimal(12, 2) @default(0)
  tax         Decimal     @db.Decimal(12, 2) @default(0)
  discount    Decimal     @db.Decimal(12, 2) @default(0)
  refundTotal Decimal     @db.Decimal(12, 2) @default(0)
  currency    String      @default("ILS")
  source      String?     // utm_source
  medium      String?     // utm_medium
  campaign    String?     // utm_campaign
  gclid       String?
  fbclid      String?
  orderedAt   DateTime
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  storeId String
  store   StoreIntegration @relation(fields: [storeId], references: [id], onDelete: Cascade)

  items       OrderItem[]
  conversions Conversion[]

  @@unique([storeId, externalId])
  @@index([storeId, orderedAt])
  @@index([gclid])
  @@index([fbclid])
}

model OrderItem {
  id         String  @id @default(cuid())
  quantity   Int
  price      Decimal @db.Decimal(12, 2)
  total      Decimal @db.Decimal(12, 2)
  refunded   Decimal @db.Decimal(12, 2) @default(0)

  orderId   String
  productId String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Conversion {
  id              String   @id @default(cuid())
  externalId      String?
  platform        Platform
  conversionType  String
  value           Decimal  @db.Decimal(12, 2) @default(0)
  currency        String   @default("ILS")
  gclid           String?
  fbclid          String?
  convertedAt     DateTime
  createdAt       DateTime @default(now())

  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id])

  @@index([platform, convertedAt])
  @@index([gclid])
}

// ─────────────────────────────────────────────────────────────────────────────
// METRICS
// ─────────────────────────────────────────────────────────────────────────────

model DailyMetric {
  id              String   @id @default(cuid())
  date            DateTime @db.Date
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  cost            Decimal  @db.Decimal(12, 2) @default(0)
  conversions     Float    @default(0)
  conversionValue Decimal  @db.Decimal(12, 2) @default(0)
  revenue         Decimal  @db.Decimal(12, 2) @default(0)
  ctr             Float?
  cpc             Decimal? @db.Decimal(12, 2)
  cpa             Decimal? @db.Decimal(12, 2)
  roas            Float?
  // Profit fields
  grossProfit     Decimal? @db.Decimal(12, 2)
  netProfit       Decimal? @db.Decimal(12, 2)
  profitMargin    Float?

  adAccountId String?
  campaignId  String?
  adAccount   AdAccount? @relation(fields: [adAccountId], references: [id], onDelete: SetNull)
  campaign    Campaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@unique([campaignId, date])
  @@index([adAccountId, date])
  @@index([campaignId, date])
}

model HourlyMetric {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  hour        Int      // 0-23
  impressions Int      @default(0)
  clicks      Int      @default(0)
  cost        Decimal  @db.Decimal(12, 2) @default(0)
  conversions Float    @default(0)

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date, hour])
  @@index([campaignId, date])
}

// ─────────────────────────────────────────────────────────────────────────────
// NEGATIVE KEYWORDS
// ─────────────────────────────────────────────────────────────────────────────

model NegativeKeyword {
  id         String    @id @default(cuid())
  text       String
  matchType  MatchType @default(BROAD)
  level      NegKwLevel @default(CAMPAIGN)
  externalId String?
  addedAt    DateTime  @default(now())
  addedBy    String?   // user id or "system"
  source     NegKwSource @default(MANUAL)

  campaignId String?
  adGroupId  String?

  @@index([campaignId])
  @@index([text])
}

model NegativeKeywordSuggestion {
  id          String          @id @default(cuid())
  query       String
  suggestion  String          // normalized negative keyword
  matchType   MatchType       @default(BROAD)
  confidence  Float           // 0-1
  riskLevel   RiskLevel       @default(LOW)
  reason      String
  wasteAmount Decimal?        @db.Decimal(12, 2)  // estimated waste
  status      SuggestionStatus @default(PENDING)
  appliedAt   DateTime?
  dismissedAt DateTime?
  createdAt   DateTime        @default(now())

  searchTermId String
  searchTerm   SearchTerm @relation(fields: [searchTermId], references: [id], onDelete: Cascade)

  @@index([searchTermId])
  @@index([status])
  @@index([confidence])
}

// ─────────────────────────────────────────────────────────────────────────────
// AI INTELLIGENCE
// ─────────────────────────────────────────────────────────────────────────────

model AiRecommendation {
  id             String             @id @default(cuid())
  type           RecommendationType
  title          String
  reason         String
  confidence     Float              // 0-1
  severity       Severity           @default(MEDIUM)
  expectedImpact String?
  payload        Json               // action-specific data
  status         RecommendationStatus @default(PENDING)
  executedAt     DateTime?
  dismissedAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  approvalRequest ApprovalRequest?

  @@index([campaignId, status])
  @@index([type, status])
  @@index([severity, status])
}

model CreativeVariant {
  id           String   @id @default(cuid())
  platform     Platform
  headline1    String
  headline2    String?
  headline3    String?
  description1 String
  description2 String?
  cta          String?
  angle        String?  // emotional hook / angle
  tone         String?
  score        Float?   // AI quality score 0-1
  approved     Boolean  @default(false)
  approvedAt   DateTime?
  publishedAt  DateTime?
  createdAt    DateTime @default(now())

  adId String?
  ad   Ad?     @relation(fields: [adId], references: [id], onDelete: SetNull)

  @@index([platform, approved])
}

// ─────────────────────────────────────────────────────────────────────────────
// ACTIONS & APPROVALS
// ─────────────────────────────────────────────────────────────────────────────

model OptimizationAction {
  id          String       @id @default(cuid())
  type        ActionType
  mode        ExecutionMode @default(DRY_RUN)
  status      ActionStatus @default(PENDING)
  payload     Json
  result      Json?
  errorMsg    String?
  executedAt  DateTime?
  createdAt   DateTime     @default(now())

  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  auditLogs AuditLog[]

  @@index([status, createdAt])
  @@index([type])
}

model ApprovalRequest {
  id           String          @id @default(cuid())
  riskLevel    RiskLevel
  title        String
  description  String
  payload      Json
  status       ApprovalStatus  @default(PENDING)
  approvedAt   DateTime?
  rejectedAt   DateTime?
  rejectedNote String?
  expiresAt    DateTime?
  createdAt    DateTime        @default(now())

  approvedById String?
  approvedBy   User?             @relation("ApprovedBy", fields: [approvedById], references: [id])

  recommendationId String?          @unique
  recommendation   AiRecommendation? @relation(fields: [recommendationId], references: [id])

  @@index([status])
  @@index([riskLevel, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// SYSTEM
// ─────────────────────────────────────────────────────────────────────────────

model SyncJob {
  id          String     @id @default(cuid())
  type        SyncType
  status      JobStatus  @default(QUEUED)
  startedAt   DateTime?
  completedAt DateTime?
  errorMsg    String?
  recordsIn   Int        @default(0)
  recordsOut  Int        @default(0)
  meta        Json?
  createdAt   DateTime   @default(now())

  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  adAccountId String?
  adAccount   AdAccount?   @relation(fields: [adAccountId], references: [id], onDelete: SetNull)
  storeId     String?
  store       StoreIntegration? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@index([orgId, type, status])
  @@index([status, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String   // e.g. "campaign.paused", "budget.updated"
  entity     String   // e.g. "Campaign"
  entityId   String?
  before     Json?
  after      Json?
  meta       Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  userId   String?
  user     User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  actionId String?
  action2  OptimizationAction? @relation(fields: [actionId], references: [id], onDelete: SetNull)

  // Relation name disambiguation
  createdById String?
  createdBy   User?  @relation("CreatedByUser", fields: [createdById], references: [id])

  @@index([entity, entityId])
  @@index([createdAt])
  @@index([userId])
}

model FeatureFlag {
  id        String   @id @default(cuid())
  key       String
  enabled   Boolean  @default(false)
  rollout   Float    @default(1.0)  // 0-1 percentage
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, key])
}

model Setting {
  id        String   @id @default(cuid())
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, key])
}

model Alert {
  id        String      @id @default(cuid())
  type      AlertType
  severity  Severity    @default(MEDIUM)
  title     String
  body      String
  read      Boolean     @default(false)
  readAt    DateTime?
  createdAt DateTime    @default(now())

  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, read])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole    { ADMIN MEMBER }
enum OrgRole     { OWNER ADMIN EDITOR VIEWER }
enum OrgPlan     { FREE PRO ENTERPRISE }
enum Platform    { GOOGLE META TIKTOK }
enum StorePlatform { WOOCOMMERCE SHOPIFY }
enum CampaignStatus { ACTIVE PAUSED REMOVED DRAFT }
enum CampaignType   { SEARCH DISPLAY SHOPPING VIDEO PMAX }
enum BudgetType     { DAILY LIFETIME }
enum AdType         { RSA DSA }
enum MatchType      { EXACT PHRASE BROAD }
enum OrderStatus    { PENDING PROCESSING COMPLETED CANCELLED REFUNDED }
enum SearchIntent   { BUYER RESEARCH COMPETITOR SUPPORT IRRELEVANT LOW_INTENT UNKNOWN }
enum RiskLevel      { LOW MEDIUM HIGH CRITICAL }
enum Severity       { LOW MEDIUM HIGH CRITICAL }
enum SuggestionStatus { PENDING APPLIED DISMISSED }
enum RecommendationType {
  RAISE_BUDGET LOWER_BUDGET PAUSE_CAMPAIGN PAUSE_KEYWORD
  ADD_NEGATIVE_KEYWORD SUGGEST_CREATIVE PROMOTE_PRODUCT FLAG_ISSUE
  INCREASE_BID DECREASE_BID
}
enum RecommendationStatus { PENDING APPROVED REJECTED EXECUTED EXPIRED }
enum ApprovalStatus  { PENDING APPROVED REJECTED EXPIRED }
enum ActionType      { BUDGET_CHANGE BID_CHANGE STATUS_CHANGE NEGATIVE_KW_ADD CREATIVE_UPDATE }
enum ActionStatus    { PENDING EXECUTING DONE FAILED ROLLED_BACK }
enum ExecutionMode   { DRY_RUN SUGGEST APPROVAL_REQUIRED AUTOMATED }
enum NegKwLevel      { CAMPAIGN AD_GROUP ACCOUNT }
enum NegKwSource     { MANUAL AI_SUGGESTED IMPORTED }
enum SyncType        { GOOGLE_ADS_CAMPAIGNS GOOGLE_ADS_SEARCH_TERMS META_CAMPAIGNS WOOCOMMERCE_PRODUCTS WOOCOMMERCE_ORDERS SHOPIFY_PRODUCTS SHOPIFY_ORDERS }
enum JobStatus       { QUEUED RUNNING DONE FAILED CANCELLED }
enum AlertType       { BUDGET_DEPLETED HIGH_CPA ZERO_CONVERSIONS ANOMALY SYSTEM }
